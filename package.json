{
  "name": "aerarium",
  "version": "0.2.5",
  "description": "Aerarium — desktop finance tracker",
  "author": "Aerarium",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && npm run build:electron && electron .\"",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "vite build && npm run build:electron && electron-builder",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.13.3",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^8.1.3",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.1"
  }
}
